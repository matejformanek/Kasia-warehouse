# Copy to .env and fill in. Never commit .env (it is gitignored).
# Per context/decisions/0023-runtime-orchestration-compose.md and
# .claude/rules/infra-as-code.md.

# --- Django -----------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# On prod set the real hostnames; ALWAYS keep 127.0.0.1,localhost so the
# web container's /healthz healthcheck passes under DEBUG=False. Keep the
# bare IP (91.98.47.1) too while the IP site is still reachable during the
# HTTPS cutover. Per 0056.
DJANGO_ALLOWED_HOSTS=kasia.cz,www.kasia.cz,127.0.0.1,localhost
DJANGO_DEBUG=0
# Comma-separated https:// origins trusted for cross-origin POSTs behind the
# TLS-terminating Caddy proxy (login, kontakt form). Leave blank on HTTP-only.
DJANGO_CSRF_TRUSTED_ORIGINS=https://kasia.cz,https://www.kasia.cz
# Mark session + CSRF cookies Secure. Set to 1 ONLY once HTTPS is live —
# on plain HTTP it would stop cookies (and thus logins) from working.
DJANGO_SECURE_COOKIES=0
# Absolute base URL (scheme + host, no trailing slash) prepended to links in
# outgoing e-mails (new-user credentials, Podpora notifications). E-mails send
# off-request so there is no host to derive — without this, links are bare
# paths a user can't click. Defaults to http://localhost:8000; set the real
# canonical host on the box. Per 0082.
SITE_BASE_URL=https://kasia.cz

# --- Postgres (consumed by both the db service and the web service) --------
POSTGRES_PASSWORD=change-me

# --- E-mail (Django SMTP backend, per 0019) --------------------------------
EMAIL_HOST=mail.kasia.cz
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=aplikace@kasia.cz
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Kasia vera <no-reply@example.cz>

# --- Deployment-only --------------------------------------------------------
# WEB_IMAGE pins the image tag pulled on the production box. Defaults to
# the locally-built `kasia-web:local` when unset; the deploy job overrides
# it to `ghcr.io/<org>/<repo>:sha-<commit>`.
# WEB_IMAGE=ghcr.io/example/kasia-warehouse:latest

# --- Restic backup (prod profile only) -------------------------------------
RESTIC_REPOSITORY=
RESTIC_PASSWORD=

# --- Analytics (decision 0076) ----------------------------------------------
# Self-hosted Umami at analytics.kasia.cz (prod profile only). Set on the
# on-box .env only; local dev + CI run without these and the public-site
# tracker tag stays absent. UMAMI_WEBSITE_ID comes from the Umami UI after
# first boot (RUNBOOK § Analytics).
UMAMI_DB_PASSWORD=
UMAMI_APP_SECRET=
UMAMI_WEBSITE_ID=
# UMAMI_SCRIPT_URL=https://analytics.kasia.cz/script.js   # default; set only to override

# --- Local development only (per 0083) --------------------------------------
# These are DEV conveniences — leave them UNSET on the prod box so the
# committed defaults (real SMTP + kasia.cz Caddyfile) apply.
#
# Serve the app on localhost (http + self-signed https, no ACME/cert attempts)
# instead of the prod kasia.cz + Let's Encrypt Caddyfile:
# CADDYFILE=./Caddyfile.dev
#
# Clickable base URL for e-mail links in dev (prod: https://kasia.cz):
# SITE_BASE_URL=http://localhost
#
# E-mail in dev: by default dev uses the SAME real SMTP as prod (mail.kasia.cz),
# so mail actually lands in your inbox. For delivery the sender MUST be a real
# @kasia.cz address (Gmail drops fake .local/.example senders): set
# DEFAULT_FROM_EMAIL (password-reset sender) to the authenticated address, and
# set the app sender in Nastavení → Odesílatel (Settings.email_from_address)
# the same way, e.g.:
# DEFAULT_FROM_EMAIL=Kasia vera <aplikace@kasia.cz>
#
# OFFLINE alternative — catch mail in the web-container log instead of sending
# (no real SMTP, nothing leaves the box; the EmailLog row is still written):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
