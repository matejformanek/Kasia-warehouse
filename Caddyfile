# Per context/decisions/0024-tls-caddy.md + 0056-domain-cutover-https.md.
#
# HTTPS cutover block. Caddy auto-provisions a Let's Encrypt cert for each
# host once DNS resolves to the box, and renews them. Canonical host is the
# apex kasia.cz; www.kasia.cz is a permanent (301) redirect to it.
#
# ⚠️ This block only works once `A kasia.cz` / `A www.kasia.cz` point at the
# box. Activating it before DNS resolves takes the site offline (no :80
# catch-all) and makes Caddy fail against Let's Encrypt's ACME endpoint,
# risking the rate limit. Merge the PR that lands this file ONLY after
# `dig +short kasia.cz` / `www.kasia.cz` return 91.98.47.1. See RUNBOOK § 5.

kasia.cz {
    reverse_proxy web:8000
    encode zstd gzip
    log {
        output stdout
        format console
    }
}

www.kasia.cz {
    redir https://kasia.cz{uri} permanent
}

# Self-hosted Umami analytics per context/decisions/0076-public-site-analytics.md.
# Sibling host block; cert auto-provisioned the same way as the apex. The
# *.kasia.cz wildcard A record already resolves here, so no DNS action needed.
analytics.kasia.cz {
    reverse_proxy umami:3000
    encode zstd gzip
    log {
        output stdout
        format console
    }
}

# Old bookmarks from the IP era. Without this, Caddy's default answer to
# `Host: 91.98.47.1` on :80 is a 308 to https://91.98.47.1 — which can never
# have a matching cert, so browsers scream "not secure". Send them to the
# canonical host instead. (https://91.98.47.1 will still warn; that's
# inherent to bare-IP TLS and not worth chasing.)
http://91.98.47.1 {
    redir https://kasia.cz{uri} permanent
}
